  "coredns": null,
  "dns_exporter": {
    "dns_exporter": {
      "modules": {
        "cf_doh": {
          "protocol": "doh",
          "query_name": "bornhack.dk",
          "query_type": "NS",
          "server": "1dot1dot1dot1.cloudflare-dns.com",
          "validate_response_flags": {
            "fail_if_any_absent": [
              "AD"
            ]
          }
        },
        "cloudflare_dns1": {
          "family": "ipv4",
          "query_type": "A",
          "server": "1.1.1.1"
        },
        "fail_additional_root": {
          "validate_additional_rrs": {
            "fail_if_all_match_regexp": [
              "[a-m].root-servers.net.*"
            ]
          }
        },
        "fail_answer_root": {
          "validate_answer_rrs": {
            "fail_if_not_matches_regexp": [
              "[a-m].root-servers.net.*"
            ]
          }
        },
        "fail_answer_root_none": {
          "validate_answer_rrs": {
            "fail_if_none_matches_regexp": [
              ".*[a-m].root-servers.net.*"
            ]
          }
        },
        "fail_auth_k_root": {
          "validate_answer_rrs": {
            "fail_if_matches_regexp": [
              ".*k.root-servers.net"
            ]
          }
        },
        "fail_not_auth": {
          "validate_response_flags": {
            "fail_if_all_absent": [
              "AA",
              "AD"
            ]
          }
        },
        "fail_recursive": {
          "validate_response_flags": {
            "fail_if_all_present": [
              "QR",
              "RA",
              "RD"
            ]
          }
        },
        "gmail_mx_v4": {
          "family": "ipv4",
          "query_name": "gmail.com",
          "query_type": "MX"
        },
        "google_dot": {
          "protocol": "dot",
          "query_name": "dns.google",
          "query_type": "AAAA",
          "server": "dns.google",
          "validate_answer_rrs": {
            "fail_if_count_ne": 2,
            "fail_if_not_matches_regexp": [
              ".*2001:4860:4860::8888",
              ".*2001:4860:4860::8844"
            ]
          }
        },
        "google_tcp": {
          "protocol": "tcp",
          "query_name": "dns.google",
          "query_type": "A",
          "server": "dns.google",
          "validate_answer_rrs": {
            "fail_if_count_ne": 2,
            "fail_if_not_matches_regexp": [
              ".*8.8.8.8",
              ".*8.8.4.4"
            ]
          }
        },
        "google_udp": {
          "protocol": "udp",
          "query_name": ".",
          "query_type": "NS",
          "server": "dns.google",
          "validate_answer_rrs": {
            "fail_if_count_ne": 13
          }
        },
        "has_ad": {
          "edns_do": true,
          "validate_response_flags": {
            "fail_if_any_absent": [
              "AD"
            ]
          }
        },
        "has_no_ad": {
          "edns_do": true,
          "validate_response_flags": {
            "fail_if_any_present": [
              "AD"
            ]
          }
        },
        "quad9_dns1": {
          "family": "ipv4",
          "query_type": "A",
          "server": "9.9.9.9"
        },
        "socks1080": {
          "proxy": "socks5://127.0.0.1:1080"
        }
      }
    }
  },
  "golang": {
