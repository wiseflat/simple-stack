{
  "adguard": {},
  "arangodb": {},
  "caddy": {
    "caddy_config": "{{ software.caddy_config | default(caddy_config_default) }}"
  },
  "code_server": {
    "timezone": "Europe/Paris",
    "password": "changeme",
    "sudo_password": "changeme"
  },
  "dolibarr": {},
  "forgejo": {},
  "freqtrade": {},
  "freshrss": {},
  "grafana": {},
  "homeassistant": {
    "homeassistant_configuration_default": {
      "http": {
        "use_x_forwarded_for": true,
        "trusted_proxies": [
          "172.17.0.0/24"
        ]
      }
    },
    "homeassistant_configuration": "{{ software.homeassistant_configuration | default(homeassistant_configuration_default) }}"
  },
  "kresus": {},
  "litellm": {
    "litellm_env": [
      {
        "key": "LITELLM_MASTER_KEY",
        "value": "sk-1234"
      },
      {
        "key": "LITELLM_SALT_KEY",
        "value": "sk-1234"
      },
      {
        "key": "DATABASE_URL",
        "value": "postgresql://llmproxy:dbpassword9090@db:5432/litellm"
      },
      {
        "key": "STORE_MODEL_IN_DB",
        "value": true
      },
      {
        "key": "OVHCLOUD_API_KEY",
        "value": "changeme"
      }
    ],
    "litellm_config": {
      "model_list": [
        {
          "model_name": "ovhcloud/gpt-oss-120b",
          "litellm_params": {
            "model": "ovhcloud/gpt-oss-120b",
            "api_key": "os.environ/OVHCLOUD_API_KEY"
          }
        }
      ]
    },
    "litellm_dbhost": "localhost"
  },
  "loki": {},
  "mariadb": {},
  "milvus": {},
  "mimir": {
    "mimir_install_node": "{{ software.install_node |default('singlenode') }}"
  },
  "minio": {},
  "mosquitto": {},
  "nextcloud": {},
  "nginx": {},
  "nodejs": {},
  "nomad": {
    "nomad_job_dir": "/var/tmp",
    "nomad_http_ip": "127.0.0.1",
    "nomad_job_name": "{{ job_name | default(domain) }}",
    "nomad_tls_host_certificate_dir": "/etc/ssl/simplestack",
    "nomad_tls_cert_server": "{{ fact_instance.datacenter }}-server-nomad.pem",
    "nomad_tls_privatekey_server": "{{ fact_instance.datacenter }}-server-nomad.key",
    "nomad_tls_ca_pubkey": "simplestack-ca.pem"
  },
